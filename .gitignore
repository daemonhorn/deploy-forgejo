# Secrets and credentials
vultr_api_key
aws_access_key
aws_secret_access_key
azure_credentials

# Operational data (instance-specific; not code)
.provision-log.json
azure_skus

# Session/scratch files
*.txt
*.tfvars
!*.tfvars.example

# Vault local state
.vault-data/
.vault.token
.vault.pid
.vault-keys

# Yubikey setup artifacts
.ykcs11_lib
ca_public.pem

# Terraform state and cache
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl
terraform/aws/.terraform/
terraform/aws/.terraform.lock.hcl
terraform/azure/.terraform/
terraform/azure/.terraform.lock.hcl
terraform/vultr/.terraform/
terraform/vultr/.terraform.lock.hcl

# Provider selection state
.last-provider

# Provider data cache (refreshed daily; not secrets)
.cache/

# Deploy artifacts
known_hosts.deploy

# Export archives (export-git.sh default output destination)
archive/*.tar.zst

# Batch-issued SSH keys and certs (sign-user-key.sh --batch output)
keys/

# Rendered templates (never committed; generated at deploy time)
files/.env
files/app.ini
files/nginx.conf
files/nginx-http.conf
