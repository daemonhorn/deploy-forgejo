APP_NAME = Forgejo

[server]
DOMAIN         = ${DOMAIN}
ROOT_URL       = https://${DOMAIN}
HTTP_PORT      = 3000
; Internal hook calls (e.g. forgejo keys) connect back to Forgejo via this URL.
; Must use 127.0.0.1 explicitly — 'localhost' resolves to ::1 (IPv6) which
; Forgejo does not listen on, causing "connection refused" in authorized_keys lookup.
LOCAL_ROOT_URL = http://127.0.0.1:3000/
SSH_DOMAIN     = ${DOMAIN}
SSH_PORT       = 2222
; SSH handled by host sshd (see sshd_forgejo.conf deployed by deploy.sh).
; Forgejo's built-in SSH server is disabled.
START_SSH_SERVER                  = false
SSH_TRUSTED_USER_CA_KEYS_FILENAME = /data/gitea/ssh/trusted-user-ca-keys.pub

[database]
DB_TYPE = postgres
HOST    = db:5432
NAME    = ${DB_NAME}
USER    = ${DB_USER}
PASSWD  = ${DB_PASSWORD}

[service]
ENABLE_BASIC_AUTHENTICATION = false
DISABLE_REGISTRATION        = true

[security]
; Prevents web-installer from running on first request before admin account exists.
INSTALL_LOCK   = true
; Pre-generated so Forgejo does not regenerate them on every restart.
SECRET_KEY     = ${FORGEJO_SECRET_KEY}
INTERNAL_TOKEN = ${FORGEJO_INTERNAL_TOKEN}

[log]
MODE  = console
LEVEL = warn
